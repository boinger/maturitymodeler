{
  "name": "maturity-modeler",
  "version": "1.0.0",
  "description": "JavaScript-based gap analysis visualization tool for maturity models",
  "main": "app.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "build": "./build.sh",
    "build:legacy": "npx webpack --mode=production",
    "analyze": "ANALYZE=true npx webpack --mode=production",
    "dev": "./build.sh fast",
    "size": "ls -lah dist/ | grep -E '\\.(js|css|html)$' && echo '--- Compressed sizes ---' && ls -lah dist/ | grep -E '\\.(gz|br)$'"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@jest/globals": "^29.7.0",
    "babel-loader": "^10.0.0",
    "core-js": "^3.45.0",
    "d3": "^7.9.0",
    "d3-array": "^3.2.4",
    "d3-format": "^3.1.0",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "webpack": "^5.101.3",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1"
  },
  "type": "module",
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/**/*.js",
      "!js/d3/**",
      "!js/require_2_3_6/**",
      "!dist/**"
    ]
  },
  "keywords": [
    "d3",
    "visualization",
    "maturity-model",
    "radar-chart"
  ],
  "author": "Jeff Vier",
  "license": "MIT"
}
