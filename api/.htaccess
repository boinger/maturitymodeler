# Force JSON content type for PHP responses
<FilesMatch "\.php$">
    Header set Content-Type "application/json; charset=utf-8"
</FilesMatch>

# Deny access to auth.php and validate.php directly (only included by config.php)
<FilesMatch "^(auth|validate)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# CORS: same-origin only (no cross-origin allowed)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
</IfModule>
